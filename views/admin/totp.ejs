<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Two-Factor Auth — WrikeXPI Admin</title>
    <link
      rel="icon"
      href="https://cdn.wrike.com/static/branding/wrike/favicons/favicon.ico"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <style>
      :root {
        --bg-body: #f0f4f8;
        --bg-card: #ffffff;
        --bg-surface: #f5f7fa;
        --bg-surface-2: #eaeff5;
        --border: #e2e8f0;
        --text-primary: #0f172a;
        --text-secondary: #475569;
        --text-muted: #94a3b8;
        --accent: #008262;
        --accent-hover: #006d52;
        --danger: #ef4444;
        --danger-soft: rgba(239, 68, 68, 0.1);
        --radius-sm: 6px;
      }

      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family:
          "Inter",
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          sans-serif;
        background: var(--bg-body);
        color: var(--text-primary);
        font-size: 14px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 24px;
      }

      .totp-card {
        width: 100%;
        max-width: 400px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 12px;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
        padding: 40px 36px 32px;
      }

      .card-brand {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        margin-bottom: 28px;
      }

      .card-brand svg.wrike-logo {
        width: 160px;
        height: auto;
        fill: #008262;
      }

      .brand-sub {
        font-size: 11px;
        font-weight: 600;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      .shield-icon {
        width: 54px;
        height: 54px;
        background: rgba(0, 130, 98, 0.08);
        border: 1.5px solid rgba(0, 130, 98, 0.3);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 0 18px 0;
        color: var(--accent);
        font-size: 22px;
      }

      .card-title {
        font-size: 22px;
        font-weight: 700;
        color: var(--text-primary);
        letter-spacing: -0.4px;
        margin-bottom: 4px;
      }

      .card-sub {
        font-size: 13px;
        color: var(--text-muted);
        margin-bottom: 26px;
      }

      .alert-error {
        display: none;
        align-items: flex-start;
        gap: 9px;
        padding: 10px 13px;
        background: var(--danger-soft);
        border: 1px solid rgba(239, 68, 68, 0.25);
        border-radius: var(--radius-sm);
        color: var(--danger);
        font-size: 13px;
        margin-bottom: 18px;
        line-height: 1.5;
      }

      .alert-error.show {
        display: flex;
      }
      .alert-error i {
        margin-top: 2px;
        flex-shrink: 0;
      }

      .form-group {
        margin-bottom: 16px;
      }

      .form-label {
        display: block;
        font-size: 11px;
        font-weight: 600;
        color: var(--text-secondary);
        margin-bottom: 6px;
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }

      .otp-input {
        width: 100%;
        padding: 14px 16px;
        background: var(--bg-surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        color: var(--text-primary);
        font-size: 24px;
        font-family: "Courier New", "Consolas", monospace;
        font-weight: 700;
        letter-spacing: 10px;
        text-align: center;
        transition:
          border-color 0.15s,
          box-shadow 0.15s;
        outline: none;
      }

      .otp-input:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(0, 224, 92, 0.15);
      }

      .otp-input::placeholder {
        color: var(--text-muted);
        letter-spacing: 8px;
        font-size: 18px;
      }

      .btn-verify {
        width: 100%;
        padding: 11px 16px;
        margin-top: 4px;
        background: var(--accent);
        color: #fff;
        border: none;
        border-radius: var(--radius-sm);
        font-size: 14px;
        font-weight: 600;
        font-family: inherit;
        cursor: pointer;
        transition: background 0.15s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        position: relative;
      }

      .btn-verify:hover:not(:disabled) {
        background: var(--accent-hover);
      }
      .btn-verify:disabled {
        opacity: 0.5;
        cursor: not-allowed;
      }
      .btn-verify.loading {
        color: transparent;
        pointer-events: none;
      }
      .btn-verify.loading::after {
        content: "";
        position: absolute;
        width: 16px;
        height: 16px;
        top: 50%;
        left: 50%;
        margin: -8px 0 0 -8px;
        border: 2px solid rgba(255, 255, 255, 0.4);
        border-top-color: #fff;
        border-radius: 50%;
        animation: spin 0.65s linear infinite;
      }

      .btn-back {
        width: 100%;
        padding: 10px 16px;
        margin-top: 8px;
        background: transparent;
        color: var(--text-secondary);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        font-size: 13.5px;
        font-weight: 500;
        font-family: inherit;
        cursor: pointer;
        transition:
          background 0.15s,
          border-color 0.15s,
          color 0.15s;
      }

      .btn-back:hover {
        background: var(--bg-surface);
        border-color: var(--text-muted);
        color: var(--text-primary);
      }

      .info-row {
        margin-top: 20px;
        font-size: 12px;
        color: var(--text-muted);
        text-align: center;
        line-height: 1.6;
      }

      @keyframes spin {
        to {
          transform: rotate(360deg);
        }
      }
    </style>
  </head>
  <body>
    <div class="totp-card">
      <div class="card-brand">
        <svg
          class="wrike-logo"
          viewBox="0 0 100 20"
          role="img"
          aria-label="Wrike logo"
        >
          <path
            d="M20.78 1.404C21.885.298 22.587 0 24.113 0h6.878c.561 0 .684.509.35.842l-11.49 11.491c-.176.176-.246.21-.352.246-.035.018-.087.018-.122.018s-.088 0-.123-.018c-.106-.035-.176-.07-.351-.246L14.85 8.281c-.175-.176-.21-.246-.245-.351-.018-.035-.018-.088-.018-.123s0-.088.018-.123c.035-.105.07-.175.245-.35l5.93-5.93zM10.745 8.649C9.64 7.544 8.92 7.263 7.395 7.263H.534c-.562 0-.685.509-.351.842l11.49 11.492c.176.175.246.21.352.245a.299.299 0 00.123.018c.035 0 .087 0 .122-.018.105-.035.176-.07.351-.245l4.053-4.07c.175-.176.21-.246.245-.351a.3.3 0 00.018-.123c0-.035 0-.088-.018-.123-.035-.105-.07-.175-.245-.351l-5.93-5.93z"
          />
          <path
            d="M71.064 4.72a1.965 1.965 0 100-3.93 1.965 1.965 0 000 3.93zm1.579 1.578h-3.158v11.035h3.158V6.298zm-9.877 11.035V12.37c0-3 2.649-2.948 4.035-2.72V6.263c-2.21-.193-3.526.421-4.123 1.614h-.07l.017-1.561h-3.07v11.018h3.21zm-22.685 0h2.474l3.79-7.087 3.666 7.087h2.509l5.632-11.035h-3.737l-3.456 7.035-3.281-7.035h-2.684l-3.456 7.07-3.281-7.07H34.52l5.561 11.035zm36.053 0h2l3.298-4.158 2.79 4.158h3.72l-4.387-6.386 3.842-4.649h-3.701l-4.386 5.544h-.07L79.275.79h-3.14v16.544zm18.228-2.368c1.351 0 2.158-.72 2.544-1.298l2.421 1.667c-.982 1.28-2.509 2.28-5.035 2.28-3.386 0-5.912-2.544-5.912-5.754 0-3.228 2.579-5.755 5.912-5.755 3.403 0 5.702 2.562 5.702 5.755v.877h-8.58c.246 1.316 1.37 2.228 2.948 2.228zm2.58-4.421c-.352-1.158-1.37-1.965-2.825-1.965-1.492 0-2.492.807-2.843 1.965h5.667z"
          />
        </svg>
        <span class="brand-sub">XPI &middot; Admin Portal</span>
      </div>

      <div class="shield-icon"><i class="fa-solid fa-shield-halved"></i></div>
      <div class="card-title">Two-Factor Auth</div>
      <div class="card-sub">
        Enter the 6-digit code from your authenticator app
      </div>

      <div class="alert-error" id="errorMessage">
        <i class="fa-solid fa-circle-exclamation"></i>
        <span id="errorText"></span>
      </div>

      <form id="totpForm" onsubmit="return false;">
        <div class="form-group">
          <label class="form-label" for="totpCode">Authentication Code</label>
          <input
            class="otp-input"
            type="text"
            id="totpCode"
            name="totpCode"
            placeholder="••••••"
            maxlength="6"
            inputmode="numeric"
            pattern="[0-9]{6}"
            required
            autocomplete="one-time-code"
          />
        </div>

        <button type="submit" class="btn-verify" id="verifyBtn">
          <i class="fa-solid fa-check"></i>
          <span id="btnText">Verify Code</span>
        </button>

        <button type="button" class="btn-back" id="backBtn">
          <i class="fa-solid fa-arrow-left" style="font-size: 11px"></i>
          Back to Login
        </button>
      </form>

      <div class="info-row">
        Open Google Authenticator, Authy, or Microsoft Authenticator<br />and
        enter the 6-digit code shown for this account.
      </div>
    </div>

    <script>
      const form = document.getElementById("totpForm");
      const errorDiv = document.getElementById("errorMessage");
      const errorText = document.getElementById("errorText");
      const verifyBtn = document.getElementById("verifyBtn");
      const btnText = document.getElementById("btnText");
      const backBtn = document.getElementById("backBtn");
      const totpInput = document.getElementById("totpCode");

      // Only allow numeric input
      totpInput.addEventListener("input", (e) => {
        e.target.value = e.target.value.replace(/[^0-9]/g, "").slice(0, 6);
        // Auto-submit when 6 digits are entered
        if (totpInput.value.length === 6) {
          form.dispatchEvent(new Event("submit"));
        }
      });

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        errorDiv.classList.remove("show");

        const totpCode = totpInput.value.trim();

        if (!totpCode || totpCode.length !== 6 || !/^\d{6}$/.test(totpCode)) {
          showError("Please enter a valid 6-digit code.");
          return;
        }

        const totpToken = sessionStorage.getItem("totp_token");
        if (!totpToken) {
          showError("Session expired. Please login again.");
          window.location.href = "/admin/login";
          return;
        }

        verifyBtn.classList.add("loading");
        verifyBtn.disabled = true;

        try {
          const response = await fetch("/api/v1/admin/totp/verify", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              totp_token: totpToken,
              totp_code: totpCode,
            }),
          });

          const data = await response.json();

          if (!response.ok) {
            throw new Error(data.message || "TOTP verification failed");
          }

          // TOTP passed — server issues a JWT; store it and clear temp auth token
          localStorage.setItem("access_token", data.data.access_token);
          sessionStorage.removeItem("totp_token");
          window.location.href = "/admin/dashboard";
        } catch (err) {
          showError(err.message);
          verifyBtn.classList.remove("loading");
          verifyBtn.disabled = false;
          totpInput.value = "";
          totpInput.focus();
        }
      });

      backBtn.addEventListener("click", () => {
        sessionStorage.removeItem("totp_token");
        window.location.href = "/admin/login";
      });

      function showError(message) {
        errorText.textContent = message;
        errorDiv.classList.add("show");
      }

      // Check session on load
      window.addEventListener("load", () => {
        if (!sessionStorage.getItem("totp_token")) {
          window.location.href = "/admin/login";
        }
        totpInput.focus();
      });
    </script>
  </body>
</html>
