<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In — WrikeXPI Admin</title>
    <link
      rel="icon"
      href="https://cdn.wrike.com/static/branding/wrike/favicons/favicon.ico"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <style>
      :root {
        --bg-body: #f0f4f8;
        --bg-card: #ffffff;
        --bg-surface: #f5f7fa;
        --bg-surface-2: #eaeff5;
        --border: #e2e8f0;
        --text-primary: #0f172a;
        --text-secondary: #475569;
        --text-muted: #94a3b8;
        --accent: #008262;
        --accent-hover: #006d52;
        --success: #00e05c;
        --danger: #ef4444;
        --danger-soft: rgba(239, 68, 68, 0.1);
        --radius-sm: 6px;
      }

      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      html,
      body {
        height: 100%;
      }

      body {
        font-family:
          "Inter",
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          sans-serif;
        background: var(--bg-body);
        color: var(--text-primary);
        font-size: 14px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 24px;
      }

      .login-card {
        width: 100%;
        max-width: 400px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 12px;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
        padding: 40px 36px 32px;
      }

      .card-brand {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        margin-bottom: 28px;
      }

      .card-brand svg.wrike-logo {
        width: 160px;
        height: auto;
        fill: #008262;
      }

      .brand-sub {
        font-size: 11px;
        font-weight: 600;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      .card-title {
        font-size: 22px;
        font-weight: 700;
        color: var(--text-primary);
        letter-spacing: -0.4px;
        margin-bottom: 4px;
      }

      .card-sub {
        font-size: 13px;
        color: var(--text-muted);
        margin-bottom: 26px;
      }

      .alert-error {
        display: none;
        align-items: flex-start;
        gap: 9px;
        padding: 10px 13px;
        background: var(--danger-soft);
        border: 1px solid rgba(239, 68, 68, 0.25);
        border-radius: var(--radius-sm);
        color: var(--danger);
        font-size: 13px;
        margin-bottom: 18px;
        line-height: 1.5;
      }

      .alert-error.show {
        display: flex;
      }

      .alert-error i {
        margin-top: 2px;
        flex-shrink: 0;
      }

      .form-group {
        margin-bottom: 14px;
      }

      .form-label {
        display: block;
        font-size: 11px;
        font-weight: 600;
        color: var(--text-secondary);
        margin-bottom: 6px;
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }

      .input-wrap {
        position: relative;
      }

      .input-prefix {
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 38px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-muted);
        font-size: 13px;
        pointer-events: none;
        border-right: 1px solid var(--border);
      }

      .form-control {
        width: 100%;
        padding: 9px 12px 9px 48px;
        background: var(--bg-surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        color: var(--text-primary);
        font-size: 14px;
        font-family: inherit;
        transition:
          border-color 0.15s,
          box-shadow 0.15s;
        outline: none;
      }

      .form-control:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(0, 130, 98, 0.15);
      }

      .form-control::placeholder {
        color: var(--text-muted);
      }

      .pw-toggle {
        position: absolute;
        right: 10px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: var(--text-muted);
        cursor: pointer;
        font-size: 13px;
        padding: 3px 5px;
        border-radius: 4px;
        transition:
          color 0.15s,
          background 0.15s;
      }

      .pw-toggle:hover {
        color: var(--text-primary);
        background: var(--bg-surface-2);
      }

      .btn-submit {
        width: 100%;
        padding: 10px 16px;
        margin-top: 6px;
        background: var(--accent);
        color: #fff;
        border: none;
        border-radius: var(--radius-sm);
        font-size: 14px;
        font-weight: 600;
        font-family: inherit;
        cursor: pointer;
        transition: background 0.15s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        position: relative;
      }

      .btn-submit:hover:not(:disabled) {
        background: var(--accent-hover);
      }

      .btn-submit:disabled {
        opacity: 0.5;
        cursor: not-allowed;
      }

      .btn-submit.loading {
        color: transparent;
        pointer-events: none;
      }

      .btn-submit.loading::after {
        content: "";
        position: absolute;
        width: 16px;
        height: 16px;
        top: 50%;
        left: 50%;
        margin: -8px 0 0 -8px;
        border: 2px solid rgba(255, 255, 255, 0.4);
        border-top-color: #fff;
        border-radius: 50%;
        animation: spin 0.65s linear infinite;
      }

      @keyframes spin {
        to {
          transform: rotate(360deg);
        }
      }

      .trust-row {
        margin-top: 22px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        font-size: 11.5px;
        color: var(--text-muted);
        flex-wrap: wrap;
      }

      .trust-dot {
        width: 3px;
        height: 3px;
        border-radius: 50%;
        background: var(--text-muted);
        flex-shrink: 0;
      }
    </style>
  </head>
  <body>
    <div class="login-card">
      <div class="card-brand">
        <svg
          class="wrike-logo"
          viewBox="0 0 100 20"
          role="img"
          aria-label="Wrike logo"
        >
          <path
            d="M20.78 1.404C21.885.298 22.587 0 24.113 0h6.878c.561 0 .684.509.35.842l-11.49 11.491c-.176.176-.246.21-.352.246-.035.018-.087.018-.122.018s-.088 0-.123-.018c-.106-.035-.176-.07-.351-.246L14.85 8.281c-.175-.176-.21-.246-.245-.351-.018-.035-.018-.088-.018-.123s0-.088.018-.123c.035-.105.07-.175.245-.35l5.93-5.93zM10.745 8.649C9.64 7.544 8.92 7.263 7.395 7.263H.534c-.562 0-.685.509-.351.842l11.49 11.492c.176.175.246.21.352.245a.299.299 0 00.123.018c.035 0 .087 0 .122-.018.105-.035.176-.07.351-.245l4.053-4.07c.175-.176.21-.246.245-.351a.3.3 0 00.018-.123c0-.035 0-.088-.018-.123-.035-.105-.07-.175-.245-.351l-5.93-5.93z"
          />
          <path
            d="M71.064 4.72a1.965 1.965 0 100-3.93 1.965 1.965 0 000 3.93zm1.579 1.578h-3.158v11.035h3.158V6.298zm-9.877 11.035V12.37c0-3 2.649-2.948 4.035-2.72V6.263c-2.21-.193-3.526.421-4.123 1.614h-.07l.017-1.561h-3.07v11.018h3.21zm-22.685 0h2.474l3.79-7.087 3.666 7.087h2.509l5.632-11.035h-3.737l-3.456 7.035-3.281-7.035h-2.684l-3.456 7.07-3.281-7.07H34.52l5.561 11.035zm36.053 0h2l3.298-4.158 2.79 4.158h3.72l-4.387-6.386 3.842-4.649h-3.701l-4.386 5.544h-.07L79.275.79h-3.14v16.544zm18.228-2.368c1.351 0 2.158-.72 2.544-1.298l2.421 1.667c-.982 1.28-2.509 2.28-5.035 2.28-3.386 0-5.912-2.544-5.912-5.754 0-3.228 2.579-5.755 5.912-5.755 3.403 0 5.702 2.562 5.702 5.755v.877h-8.58c.246 1.316 1.37 2.228 2.948 2.228zm2.58-4.421c-.352-1.158-1.37-1.965-2.825-1.965-1.492 0-2.492.807-2.843 1.965h5.667z"
          />
        </svg>
        <span class="brand-sub">XPI &middot; Admin Portal</span>
      </div>

      <div class="card-title">Admin Sign In</div>
      <div class="card-sub">Enter your credentials to access the dashboard</div>

      <div class="alert-error" id="errorMessage">
        <i class="fa-solid fa-circle-exclamation"></i>
        <span id="errorText"></span>
      </div>

      <form id="loginForm" autocomplete="off" onsubmit="return false;">
        <div class="form-group">
          <label class="form-label" for="username">Username</label>
          <div class="input-wrap">
            <div class="input-prefix"><i class="fa-solid fa-user"></i></div>
            <input
              class="form-control"
              type="text"
              id="username"
              placeholder="your-username"
              required
              autocomplete="off"
            />
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="password">Password</label>
          <div class="input-wrap">
            <div class="input-prefix"><i class="fa-solid fa-lock"></i></div>
            <input
              class="form-control"
              type="password"
              id="password"
              placeholder="••••••••••"
              required
              autocomplete="off"
            />
            <button type="button" class="pw-toggle" id="pwToggle" tabindex="-1">
              <i class="fa-regular fa-eye" id="pwIcon"></i>
            </button>
          </div>
        </div>

        <button type="submit" class="btn-submit" id="loginBtn">
          <i class="fa-solid fa-arrow-right-to-bracket"></i>
          <span>Sign In</span>
        </button>
      </form>

      <div class="trust-row">
        <i
          class="fa-solid fa-shield-halved"
          style="color: var(--success); font-size: 11px"
        ></i>
        <span>Secure connection</span>
        <span class="trust-dot"></span>
        <span>2FA enabled</span>
        <span class="trust-dot"></span>
        <span>Encrypted storage</span>
      </div>
    </div>

    <script>
      // If already authenticated, skip the login page
      if (localStorage.getItem("access_token")) {
        window.location.replace("/admin/dashboard");
      }

      const form = document.getElementById("loginForm");
      const errDiv = document.getElementById("errorMessage");
      const errText = document.getElementById("errorText");
      const loginBtn = document.getElementById("loginBtn");
      const pwInput = document.getElementById("password");
      const pwToggle = document.getElementById("pwToggle");
      const pwIcon = document.getElementById("pwIcon");

      pwToggle.addEventListener("click", function () {
        const shown = pwInput.type === "text";
        pwInput.type = shown ? "password" : "text";
        pwIcon.className = shown
          ? "fa-regular fa-eye"
          : "fa-regular fa-eye-slash";
      });

      form.addEventListener("submit", async function (e) {
        e.preventDefault();
        errDiv.classList.remove("show");

        const username = document.getElementById("username").value.trim();
        const password = pwInput.value;

        if (!username || !password) {
          showError("Please enter your username and password.");
          return;
        }

        loginBtn.classList.add("loading");
        loginBtn.disabled = true;

        try {
          const res = await fetch("/api/v1/admin/login", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ username, password }),
          });

          const data = await res.json();
          if (!res.ok) throw new Error(data.message || "Login failed");

          if (data.data.totp_required) {
            // Store temporary totp token only for the TOTP step
            sessionStorage.setItem("totp_token", data.data.totp_token);
            window.location.href = "/admin/totp";
          } else {
            // No TOTP — JWT issued immediately
            localStorage.setItem("access_token", data.data.access_token);
            window.location.href = "/admin/dashboard";
          }
        } catch (err) {
          showError(err.message || "Login failed. Please try again.");
          loginBtn.classList.remove("loading");
          loginBtn.disabled = false;
        }
      });

      function showError(msg) {
        errText.textContent = msg;
        errDiv.classList.add("show");
      }
    </script>
  </body>
</html>
