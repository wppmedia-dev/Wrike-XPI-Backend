<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard - WrikeXPI</title>
  <link rel="icon" href="https://cdn.wrike.com/static/branding/wrike/favicons/favicon.ico" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: linear-gradient(-45deg, #1f1c2c, #928dab, #2e2e52, #515175);
      background-size: 400% 400%;
      animation: gradient 15s ease infinite;
      min-height: 100vh;
      color: #fff;
    }

    @keyframes gradient {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }

    .container {
      display: grid;
      grid-template-columns: 250px 1fr;
      gap: 0;
      min-height: 100vh;
    }

    /* Sidebar */
    .sidebar {
      backdrop-filter: blur(16px);
      background-color: rgba(255, 255, 255, 0.06);
      border-right: 1px solid rgba(255, 255, 255, 0.15);
      padding: 20px;
      position: fixed;
      left: 0;
      top: 0;
      height: 100vh;
      width: 250px;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
    }

    .sidebar-content {
      flex: 1;
    }

    .sidebar-footer {
      padding-top: 20px;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      margin-top: auto;
    }

    .sidebar-header {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 30px;
      padding-bottom: 20px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .sidebar-logo {
      width: 40px;
      height: 40px;
      background: rgba(76, 175, 80, 0.2);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 2px solid rgba(76, 175, 80, 0.5);
      font-size: 1.2rem;
    }

    .sidebar-brand {
      font-size: 1rem;
      font-weight: 700;
    }

    .nav-menu {
      list-style: none;
    }

    .nav-item {
      margin-bottom: 10px;
    }

    .nav-link {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 16px;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 8px;
      color: #ccc;
      cursor: pointer;
      transition: all 0.3s ease;
      text-decoration: none;
      user-select: none;
    }

    .nav-link:hover {
      background: rgba(255, 255, 255, 0.08);
      border-color: rgba(255, 255, 255, 0.15);
      color: #fff;
    }

    .nav-link.active {
      background: rgba(76, 175, 80, 0.2);
      border-color: rgba(76, 175, 80, 0.4);
      color: #81c784;
    }

    .nav-icon {
      width: 20px;
      text-align: center;
    }

    /* Main Content */
    .main-content {
      margin-left: 250px;
      padding: 30px;
      overflow-y: auto;
      max-height: 100vh;
      width: calc(100vw - 250px);
      display: flex;
      flex-direction: column;
    }

    /* Header */
    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      backdrop-filter: blur(16px);
      background-color: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: 16px;
      padding: 20px 30px;
      margin-bottom: 30px;
    }

    .header h1 {
      font-size: 1.8rem;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .header-actions {
      display: flex;
      gap: 15px;
    }

    .logout-btn {
      width: 100%;
      padding: 12px 16px;
      background: rgba(244, 67, 54, 0.2);
      border: 1px solid rgba(244, 67, 54, 0.4);
      color: #ff7675;
      border-radius: 8px;
      cursor: pointer;
      transition: all 0.3s ease;
      font-weight: 500;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      text-align: center;
    }

    .logout-btn:hover {
      background: rgba(244, 67, 54, 0.3);
      border-color: rgba(244, 67, 54, 0.6);
    }

    /* Content Pages */
    .page {
      display: none;
    }

    .page.active {
      display: block;
    }

    /* Card */
    .card {
      backdrop-filter: blur(16px);
      background-color: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: 16px;
      padding: 30px;
      margin-bottom: 20px;
    }

    .card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
    }

    .card-title {
      font-size: 1.4rem;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .btn {
      padding: 10px 20px;
      background: #4CAF50;
      color: white;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      transition: all 0.3s ease;
      font-weight: 500;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .btn:hover {
      background: #45a049;
      transform: translateY(-2px);
    }

    .btn-danger {
      background: rgba(244, 67, 54, 0.3);
      border: 1px solid rgba(244, 67, 54, 0.5);
      color: #ff7675;
      padding: 8px 16px;
      font-size: 0.9rem;
    }

    .btn-danger:hover {
      background: rgba(244, 67, 54, 0.4);
    }

    .btn-edit {
      background: rgba(33, 150, 243, 0.3);
      border: 1px solid rgba(33, 150, 243, 0.5);
      color: #64b5f6;
      padding: 8px 16px;
      font-size: 0.9rem;
    }

    .btn-edit:hover {
      background: rgba(33, 150, 243, 0.4);
    }

    /* Table */
    .table-container {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 20px;
      min-width: 1000px;
    }

    thead {
      background: rgba(255, 255, 255, 0.08);
      border-bottom: 1px solid rgba(255, 255, 255, 0.15);
    }

    th {
      padding: 15px;
      text-align: left;
      font-weight: 600;
      color: #e0e0e0;
    }

    td {
      padding: 15px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      word-break: break-word;
    }

    tr:hover {
      background: rgba(255, 255, 255, 0.04);
    }

    .env-type {
      display: inline-block;
      padding: 6px 12px;
      border-radius: 6px;
      font-size: 0.9rem;
      font-weight: 500;
    }

    .env-api {
      background: rgba(33, 150, 243, 0.2);
      color: #64b5f6;
    }

    .env-automation {
      background: rgba(76, 175, 80, 0.2);
      color: #81c784;
    }

    .masked-value {
      font-family: 'Courier New', monospace;
      color: #9ae6b4;
    }

    .actions {
      display: flex;
      gap: 10px;
    }

    /* Modal */
    .modal {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.7);
      z-index: 1000;
      justify-content: center;
      align-items: center;
    }

    .modal.show {
      display: flex;
    }

    .modal-content {
      backdrop-filter: blur(16px);
      background-color: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: 16px;
      padding: 30px;
      max-width: 500px;
      width: 90%;
      max-height: 80vh;
      overflow-y: auto;
    }

    .modal-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
      padding-bottom: 15px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .modal-title {
      font-size: 1.3rem;
      font-weight: 600;
    }

    .close-btn {
      background: none;
      border: none;
      color: #ccc;
      font-size: 1.5rem;
      cursor: pointer;
      transition: color 0.3s ease;
    }

    .close-btn:hover {
      color: #fff;
    }

    .form-group {
      margin-bottom: 20px;
    }

    label {
      display: block;
      font-size: 0.9rem;
      margin-bottom: 8px;
      color: #e0e0e0;
      font-weight: 500;
    }

    input[type="text"],
    input[type="password"],
    select {
      width: 100%;
      padding: 10px 14px;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 8px;
      color: white;
      font-size: 0.9rem;
      transition: all 0.3s ease;
      font-family: inherit;
    }

    select option {
      background: #1f1c2c;
      color: white;
      padding: 10px;
    }

    select option:checked {
      background: linear-gradient(#4CAF50, #4CAF50);
      background-color: #4CAF50 !important;
      color: white;
    }

    /* Toggle Button */
    .toggle-group {
      display: flex;
      align-items: center;
      gap: 15px;
      margin-bottom: 20px;
    }

    .toggle-label {
      font-size: 0.9rem;
      color: #e0e0e0;
      font-weight: 500;
      margin: 0;
    }

    .toggle-switch {
      position: relative;
      display: inline-block;
      width: 50px;
      height: 28px;
    }

    .toggle-switch input {
      opacity: 0;
      width: 0;
      height: 0;
    }

    .toggle-slider {
      position: absolute;
      cursor: pointer;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-color: rgba(255, 255, 255, 0.2);
      border: 1px solid rgba(255, 255, 255, 0.3);
      border-radius: 28px;
      transition: 0.3s;
    }

    .toggle-slider:before {
      position: absolute;
      content: "";
      height: 22px;
      width: 22px;
      left: 2px;
      bottom: 2px;
      background-color: white;
      border-radius: 50%;
      transition: 0.3s;
    }

    input:checked + .toggle-slider {
      background-color: #4CAF50;
      border-color: #45a049;
    }

    input:checked + .toggle-slider:before {
      transform: translateX(22px);
    }

    .toggle-status {
      font-size: 0.85rem;
      color: #81c784;
      min-width: 60px;
    }

    .toggle-status.inactive {
      color: #ff7675;
    }

    input:focus,
    select:focus {
      outline: none;
      background: rgba(255, 255, 255, 0.12);
      border-color: rgba(76, 175, 80, 0.5);
      box-shadow: 0 0 12px rgba(76, 175, 80, 0.2);
    }

    input::placeholder {
      color: rgba(255, 255, 255, 0.5);
    }

    .modal-actions {
      display: flex;
      gap: 10px;
      margin-top: 25px;
      justify-content: flex-end;
    }

    .btn-save {
      background: #4CAF50;
    }

    .btn-save:hover {
      background: #45a049;
    }

    .btn-cancel {
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.2);
      color: #ccc;
    }

    .btn-cancel:hover {
      background: rgba(255, 255, 255, 0.15);
    }

    /* Alerts */
    .alert {
      padding: 12px 16px;
      border-radius: 8px;
      margin-bottom: 15px;
      display: none;
      animation: slideIn 0.3s ease;
    }

    .alert.show {
      display: block;
    }

    .alert-success {
      background: rgba(76, 175, 80, 0.1);
      border: 1px solid rgba(76, 175, 80, 0.3);
      color: #81c784;
    }

    .alert-error {
      background: rgba(244, 67, 54, 0.1);
      border: 1px solid rgba(244, 67, 54, 0.3);
      color: #ff7675;
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateY(-10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* Pagination */
    .pagination {
      display: flex;
      gap: 10px;
      justify-content: center;
      margin-top: 20px;
      flex-wrap: wrap;
    }

    .pagination button,
    .pagination span {
      padding: 8px 12px;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: 6px;
      color: #ccc;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .pagination button:hover {
      background: rgba(255, 255, 255, 0.12);
    }

    .pagination .active {
      background: rgba(76, 175, 80, 0.3);
      border-color: rgba(76, 175, 80, 0.5);
      color: #81c784;
    }

    .pagination span {
      cursor: default;
      background: transparent;
      border: none;
    }

    .empty-state {
      text-align: center;
      padding: 40px;
      color: #999;
    }

    .empty-state-icon {
      font-size: 3rem;
      margin-bottom: 15px;
    }

    @media (max-width: 768px) {
      .container {
        grid-template-columns: 1fr;
      }

      .sidebar {
        width: 100%;
        height: auto;
        position: relative;
      }

      .main-content {
        margin-left: 0;
        padding: 20px;
      }

      .header {
        flex-direction: column;
        gap: 15px;
        text-align: center;
      }
    }

    /* Button Loader */
    .btn-save-loading {
      position: relative;
      color: transparent;
    }

    .btn-save-loading:after {
      content: "";
      position: absolute;
      width: 16px;
      height: 16px;
      top: 50%;
      left: 50%;
      margin-left: -8px;
      margin-top: -8px;
      border: 2px solid rgba(255, 255, 255, 0.3);
      border-radius: 50%;
      border-top-color: white;
      animation: spinner 0.8s linear infinite;
    }

    @keyframes spinner {
      to { transform: rotate(360deg); }
    }

    .btn:disabled {
      opacity: 0.7;
      cursor: not-allowed;
    }
  </style>
</head>
<body>
  <div class="container">
    <!-- Sidebar -->
    <div class="sidebar">
      <div class="sidebar-content">
        <div class="sidebar-header">
          <div class="sidebar-logo">⚙️</div>
          <div class="sidebar-brand">WrikeXPI Admin</div>
        </div>
        <ul class="nav-menu">
          <li class="nav-item">
            <a class="nav-link active" onclick="showPage('environment')">
              <span class="nav-icon">🌍</span>
              <span>Environment</span>
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" onclick="showPage('settings')">
              <span class="nav-icon">⚙️</span>
              <span>Settings</span>
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" onclick="showPage('users')">
              <span class="nav-icon">👥</span>
              <span>Users</span>
            </a>
          </li>
        </ul>
      </div>
      <div class="sidebar-footer">
        <button class="logout-btn" onclick="logout()">
          <i class="fas fa-sign-out-alt"></i>
          Logout
        </button>
      </div>
    </div>

    <!-- Main Content -->
    <div class="main-content">
      <!-- Header -->
      <div class="header">
        <h1>
          <span>Admin Dashboard</span>
        </h1>
      </div>

      <!-- Environment Page -->
      <div class="page active" id="page-environment">
        <div class="card">
          <div class="card-header">
            <div class="card-title">Environments</div>
            <button class="btn" onclick="openAddModal()">
              <i class="fas fa-plus"></i>
              Add Environment
            </button>
          </div>

          <div id="alertContainer"></div>

          <div class="table-container">
            <table id="environmentTable">
              <thead>
                <tr>
                  <th>Environment Name</th>
                  <th>API Client ID</th>
                  <th>API Client Secret</th>
                  <th>Automation Client ID</th>
                  <th>Automation Client Secret</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody id="tableBody">
                <tr>
                  <td colspan="7" class="empty-state">
                    <div class="empty-state-icon">📭</div>
                    <p>No environments found</p>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>

          <div class="pagination" id="pagination"></div>
        </div>
      </div>

      <!-- Settings Page -->
      <div class="page" id="page-settings">
        <div class="card">
          <div class="card-title">⚙️ Settings</div>
          <p style="margin-top: 20px; color: #ccc;">Settings page - Coming soon</p>
        </div>
      </div>

      <!-- Users Page -->
      <div class="page" id="page-users">
        <div class="card">
          <div class="card-title">👥 Users</div>
          <p style="margin-top: 20px; color: #ccc;">Users management page - Coming soon</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Add/Edit Modal -->
  <div class="modal" id="envModal">
    <div class="modal-content">
      <div class="modal-header">
        <h2 class="modal-title" id="modalTitle">Add Environment</h2>
        <button class="close-btn" onclick="closeModal()">&times;</button>
      </div>

      <form id="envForm" onsubmit="saveEnvironment(event)">
        <div class="form-group">
          <label>Environment Name *</label>
          <input type="text" id="envName" placeholder="e.g., Production, Staging, Development" required />
        </div>

        <div style="border-top: 1px solid rgba(255, 255, 255, 0.1); padding-top: 15px; margin-top: 15px;">
          <!-- <h4 style="font-size: 0.95rem; margin-bottom: 12px; color: #e0e0e0;">API Credentials</h4> -->
          <div class="form-group">
            <label>API Client ID</label>
            <input type="text" id="apiClientId" placeholder="Enter API Client ID" />
          </div>
          <div class="form-group">
            <label>API Client Secret</label>
            <input type="password" id="apiClientSecret" placeholder="Enter API Client Secret" />
          </div>
        </div>

        <div style="border-top: 1px solid rgba(255, 255, 255, 0.1); padding-top: 15px; margin-top: 15px;">
          <!-- <h4 style="font-size: 0.95rem; margin-bottom: 12px; color: #e0e0e0;">Automation Credentials</h4> -->
          <div class="form-group">
            <label>Automation Client ID</label>
            <input type="text" id="automationClientId" placeholder="Enter Automation Client ID" />
          </div>
          <div class="form-group">
            <label>Automation Client Secret</label>
            <input type="password" id="automationClientSecret" placeholder="Enter Automation Client Secret" />
          </div>
        </div>

        <div class="toggle-group">
          <label class="toggle-label">Status</label>
          <label class="toggle-switch">
            <input type="checkbox" id="isActive" checked />
            <span class="toggle-slider"></span>
          </label>
          <span class="toggle-status" id="statusLabel">Active</span>
        </div>

        <div class="modal-actions">
          <button type="button" class="btn btn-cancel" onclick="closeModal()">Cancel</button>
          <button type="submit" class="btn btn-save" id="saveBtnSubmit">Save</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    const sessionToken = sessionStorage.getItem("session_token");
    const itemsPerPage = 10;
    let currentPage = 1;
    let environments = [];
    let editingId = null;

    if (!sessionToken) {
      window.location.href = "/admin/login";
    }

    window.addEventListener("load", loadEnvironments);

    function showPage(pageId) {
      // Hide all pages
      document.querySelectorAll(".page").forEach(page => {
        page.classList.remove("active");
      });
      document.querySelectorAll(".nav-link").forEach(link => {
        link.classList.remove("active");
      });

      // Show selected page
      document.getElementById(`page-${pageId}`).classList.add("active");
      event.target.closest(".nav-link").classList.add("active");
    }

    async function loadEnvironments() {
      try {
        const response = await fetch(`/api/v1/admin/credentials?session_token=${sessionToken}`);
        const data = await response.json();

        environments = [];

        if (data.success && Array.isArray(data.data)) {
          environments = data.data.map(cred => ({
            id: cred.id,
            environment_name: cred.environment_name || "",
            api_client_id: cred.api_client_id || "",
            api_client_secret: cred.api_client_secret || "",
            automation_client_id: cred.automation_client_id || "",
            automation_client_secret: cred.automation_client_secret || "",
            is_active: cred.is_active,
          }));
        }

        renderTable();
      } catch (err) {
        showAlert("Error loading environments", "error");
        console.error("Error:", err);
      }
    }

    function renderTable() {
      const tbody = document.getElementById("tableBody");
      const start = (currentPage - 1) * itemsPerPage;
      const end = start + itemsPerPage;
      const paginatedData = environments.slice(start, end);

      if (paginatedData.length === 0) {
        tbody.innerHTML = `
          <tr>
            <td colspan="7" class="empty-state">
              <div class="empty-state-icon">📭</div>
              <p>No environments found</p>
            </td>
          </tr>
        `;
        document.getElementById("pagination").innerHTML = "";
        return;
      }

      tbody.innerHTML = paginatedData
        .map(
          (env) => `
        <tr>
          <td><strong>${env.environment_name}</strong></td>
          <td>${maskString(env.api_client_id)}</td>
          <td><span class="masked-value">${env.api_client_secret ? '●●●●●●●●' : '-'}</span></td>
          <td>${maskString(env.automation_client_id)}</td>
          <td><span class="masked-value">${env.automation_client_secret ? '●●●●●●●●' : '-'}</span></td>
          <td><span style="color: ${env.is_active ? '#81c784' : '#ff7675'};">${env.is_active ? '✓ Active' : '✗ Inactive'}</span></td>
          <td>
            <div class="actions">
              <button class="btn btn-edit" onclick="editEnvironment('${env.id}')">
                <i class="fas fa-edit"></i> Edit
              </button>
              <button class="btn btn-danger" onclick="deleteEnvironment('${env.id}', '${env.environment_name}')">
                <i class="fas fa-trash"></i> Delete
              </button>
            </div>
          </td>
        </tr>
      `
        )
        .join("");

      renderPagination();
    }

    function renderPagination() {
      const pageCount = Math.ceil(environments.length / itemsPerPage);
      const paginationDiv = document.getElementById("pagination");

      if (pageCount <= 1) {
        paginationDiv.innerHTML = "";
        return;
      }

      let html = "";

      if (currentPage > 1) {
        html += `<button onclick="goToPage(${currentPage - 1})">← Previous</button>`;
      }

      for (let i = 1; i <= pageCount; i++) {
        if (
          i === 1 ||
          i === pageCount ||
          (i >= currentPage - 1 && i <= currentPage + 1)
        ) {
          html += `<button class="${i === currentPage ? 'active' : ''}" onclick="goToPage(${i})">${i}</button>`;
        } else if (i === currentPage - 2 || i === currentPage + 2) {
          html += `<span>...</span>`;
        }
      }

      if (currentPage < pageCount) {
        html += `<button onclick="goToPage(${currentPage + 1})">Next →</button>`;
      }

      paginationDiv.innerHTML = html;
    }

    function goToPage(page) {
      currentPage = page;
      renderTable();
    }

    function maskString(str) {
      if (!str || str.length === 0) return "N/A";
      if (str.length <= 6) {
        return str.substring(0, 3) + "●●●";
      }
      return str.substring(0, 6) + "●●●●●●";
    }

    function openAddModal() {
      editingId = null;
      document.getElementById("modalTitle").textContent = "Add Environment";
      document.getElementById("envForm").reset();
      document.getElementById("envName").disabled = false;
      document.getElementById("envModal").classList.add("show");
    }

    function editEnvironment(id) {
      editingId = id;
      const env = environments.find((e) => e.id === id);

      if (!env) return;

      document.getElementById("modalTitle").textContent = `Edit ${env.environment_name}`;
      document.getElementById("envName").value = env.environment_name;
      document.getElementById("envName").disabled = true;
      document.getElementById("apiClientId").value = env.api_client_id;
      document.getElementById("apiClientSecret").value = env.api_client_secret;
      document.getElementById("automationClientId").value = env.automation_client_id;
      document.getElementById("automationClientSecret").value = env.automation_client_secret;
      document.getElementById("isActive").checked = env.is_active;
      document.getElementById("statusLabel").textContent = env.is_active ? "Active" : "Inactive";
      document.getElementById("statusLabel").classList.toggle("inactive", !env.is_active);

      document.getElementById("envModal").classList.add("show");
    }

    function closeModal() {
      document.getElementById("envModal").classList.remove("show");
      editingId = null;
    }

    // Toggle status label update
    document.addEventListener("DOMContentLoaded", () => {
      const statusToggle = document.getElementById("isActive");
      const statusLabel = document.getElementById("statusLabel");
      if (statusToggle) {
        statusToggle.addEventListener("change", () => {
          statusLabel.textContent = statusToggle.checked ? "Active" : "Inactive";
          statusLabel.classList.toggle("inactive", !statusToggle.checked);
        });
      }
    });

    async function saveEnvironment(event) {
      event.preventDefault();

      const envName = document.getElementById("envName").value;
      const apiClientId = document.getElementById("apiClientId").value;
      const apiClientSecret = document.getElementById("apiClientSecret").value;
      const automationClientId = document.getElementById("automationClientId").value;
      const automationClientSecret = document.getElementById("automationClientSecret").value;
      const isActive = document.getElementById("isActive").checked;

      if (!envName) {
        showAlert("Environment name is required", "error");
        return;
      }

      // At least one credential must be provided
      if (!apiClientId && !apiClientSecret && !automationClientId && !automationClientSecret) {
        showAlert("Please provide at least one credential (API or Automation)", "error");
        return;
      }

      // Disable and show loader on save button
      const saveBtn = document.getElementById("saveBtnSubmit");
      const originalText = saveBtn.textContent;
      saveBtn.disabled = true;
      saveBtn.classList.add("btn-save-loading");

      try {
        const payload = {
          session_token: sessionToken,
          environment_name: envName,
          api_client_id: apiClientId || undefined,
          api_client_secret: apiClientSecret || undefined,
          automation_client_id: automationClientId || undefined,
          automation_client_secret: automationClientSecret || undefined,
        };

        if (editingId) {
          payload.id = editingId;
        }

        const response = await fetch("/api/v1/admin/credentials", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });

        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.message || "Failed to save environment");
        }

        showAlert(`Environment ${editingId ? "updated" : "added"} successfully!`, "success");
        closeModal();
        loadEnvironments();
      } catch (err) {
        showAlert(err.message || "An error occurred while saving", "error");
        console.error("Error:", err);
      } finally {
        // Restore button state
        saveBtn.disabled = false;
        saveBtn.classList.remove("btn-save-loading");
        saveBtn.textContent = originalText;
      }
    }

    async function deleteEnvironment(id, name) {
      if (
        !confirm(
          `Are you sure you want to delete "${name}"? This action cannot be undone.`
        )
      ) {
        return;
      }

      try {
        const response = await fetch(`/api/v1/admin/credentials/${id}?session_token=${sessionToken}`, {
          method: "DELETE",
        });

        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.message || "Failed to delete environment");
        }

        showAlert("Environment deleted successfully!", "success");
        loadEnvironments();
      } catch (err) {
        showAlert(err.message, "error");
      }
    }

    function showAlert(message, type) {
      const alertContainer = document.getElementById("alertContainer");
      const alertDiv = document.createElement("div");
      alertDiv.className = `alert alert-${type} show`;
      alertDiv.textContent = message;

      alertContainer.innerHTML = "";
      alertContainer.appendChild(alertDiv);

      setTimeout(() => {
        alertDiv.remove();
      }, 5000);
    }

    async function logout() {
      try {
        await fetch("/api/v1/admin/logout", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ session_token: sessionToken }),
        });
      } finally {
        sessionStorage.removeItem("session_token");
        window.location.href = "/admin/login";
      }
    }

    // Close modal on outside click
    document.getElementById("envModal").addEventListener("click", (e) => {
      if (e.target.id === "envModal") {
        closeModal();
      }
    });
  </script>
</body>
</html>
