      /* ── Toggle status ────────────────────────────────────── */
      async function puToggle(userId, is_active) {
        const confirmed = await Swal.fire({
          title: (is_active ? "Enable" : "Disable") + " user?",
          icon: "warning",
          showCancelButton: true,
          confirmButtonText: is_active ? "Enable" : "Disable",
          confirmButtonColor: is_active ? "#008262" : "#ef4444",
        });
        if (!confirmed.isConfirmed) return;

        try {
          const res = await fetch(
            "/api/v1/admin/portal-users/" + userId + "/status",
            {
              method: "PATCH",
              headers: { ...authHeaders(), "Content-Type": "application/json" },
              body: JSON.stringify({ is_active }),
            },
          );
          const json = await res.json();
          if (!res.ok || !json.success) throw new Error(json.message);
          toast("User " + (is_active ? "enabled" : "disabled"), "success");
          await loadPortalUsers();
        } catch (err) {
          toast(err.message, "error");
        }
      }

      /* ── Manage Environments ──────────────────────────────── */
      async function puOpenAssignEnv(userId, username) {
        puAssignId = userId;
        document.getElementById("puAssignEnvUsername").textContent = username;
        document
          .getElementById("puAssignEnvModalBackdrop")
          .classList.add("open");
        await puLoadEnvModal(userId);
      }

      async function puLoadEnvModal(userId) {
        const list = document.getElementById("puAssignedEnvList");
        const sel = document.getElementById("puAssignEnvSelect");
        const noMsg = document.getElementById("puNoAvailEnvMsg");
        const addSection = document.getElementById("puAssignNewEnvSection");

        list.innerHTML =
          '<div style="color:var(--text-muted);font-size:13px;">Loading...</div>';

        try {
          // Fetch user's environments + all credentials in parallel
          const [userEnvsRes, allCredsRes] = await Promise.all([
            fetch("/api/v1/admin/portal-users/" + userId + "/environments", {
              headers: authHeaders(),
            }),
            fetch("/api/v1/admin/credentials", { headers: authHeaders() }),
          ]);

          const userEnvsJson = await userEnvsRes.json();
          const allCredsJson = await allCredsRes.json();

          const userEnvs = userEnvsJson.data || [];
          const unassigned = (allCredsJson.data || []).filter(
            (e) => !e.owner_id && e.is_active && !e.deleted_at,
          );

          // Render assigned list
          if (!userEnvs.length) {
            list.innerHTML =
              '<div style="color:var(--text-muted);font-size:13px;padding:8px 0;"><i class="fa-solid fa-circle-info" style="margin-right:5px;"></i>No environments assigned yet.</div>';
          } else {
            list.innerHTML = userEnvs
              .map(
                (env) =>
                  '<div style="display:flex;align-items:center;justify-content:space-between;padding:9px 12px;background:var(--bg-surface);border:1px solid var(--border);border-radius:var(--radius-sm);margin-bottom:6px;">' +
                  '<span style="font-size:13px;font-weight:500;">' +
                  '<i class="fa-solid fa-circle-dot" style="color:var(--success);margin-right:7px;font-size:9px;"></i>' +
                  escHtml(env.environment_name) +
                  "</span>" +
                  '<button class="btn btn-ghost" style="height:26px;padding:0 10px;font-size:12px;color:var(--danger);border-color:rgba(239,68,68,0.3);" onclick="puRevokeEnv(\'' +
                  userId +
                  "','" +
                  env.id +
                  '\')"><i class="fa-solid fa-link-slash"></i> Revoke</button>' +
                  "</div>",
              )
              .join("");
          }

          // Render unassigned dropdown
          sel.innerHTML = '<option value="">Select environment…</option>';
          unassigned.forEach((env) => {
            const opt = document.createElement("option");
            opt.value = env.id;
            opt.textContent = env.environment_name;
            sel.appendChild(opt);
          });

          if (!unassigned.length) {
            sel.style.display = "none";
            document
              .getElementById("puAddEnvToUserBtn")
              .setAttribute("disabled", "true");
            noMsg.style.display = "block";
          } else {
            sel.style.display = "";
            document
              .getElementById("puAddEnvToUserBtn")
              .removeAttribute("disabled");
            noMsg.style.display = "none";
          }
        } catch (err) {
          list.innerHTML =
            '<div style="color:var(--danger);font-size:13px;">Failed to load environments.</div>';
        }
      }

      async function puRevokeEnv(userId, envId) {
        try {
          const res = await fetch(
            "/api/v1/admin/portal-users/" +
              userId +
              "/environments?env_id=" +
              envId,
            { method: "DELETE", headers: authHeaders() },
          );
          const json = await res.json();
          if (!res.ok || !json.success) throw new Error(json.message);
          toast("Environment revoked", "success");
          await puLoadEnvModal(userId);
        } catch (err) {
          toast(err.message, "error");
        }
      }

      document
        .getElementById("puAddEnvToUserBtn")
        .addEventListener("click", async () => {
          const env_id = document.getElementById("puAssignEnvSelect").value;
          if (!env_id) {
            toast("Select an environment first", "warning");
            return;
          }

          const btn = document.getElementById("puAddEnvToUserBtn");
          btn.disabled = true;

          try {
            const res = await fetch(
              "/api/v1/admin/portal-users/" + puAssignId + "/environments",
              {
                method: "POST",
                headers: {
                  ...authHeaders(),
                  "Content-Type": "application/json",
                },
                body: JSON.stringify({ env_id }),
              },
            );
            const json = await res.json();
            if (!res.ok || !json.success) throw new Error(json.message);
            toast("Environment assigned", "success");
            await puLoadEnvModal(puAssignId);
          } catch (err) {
            toast(err.message, "error");
          } finally {
            btn.disabled = false;
          }
        });

      document
        .getElementById("puCloseAssignEnvModal")
        .addEventListener("click", () =>
          document
            .getElementById("puAssignEnvModalBackdrop")
            .classList.remove("open"),
        );
      document
        .getElementById("puDoneAssignEnvBtn")
        .addEventListener("click", () =>
          document
            .getElementById("puAssignEnvModalBackdrop")
            .classList.remove("open"),
        );

      /* ── Load when Users tab is clicked ──────────────────── */
      document
        .querySelector('[data-page="users"]')
        .addEventListener("click", loadPortalUsers);
    </script>
  </body>
</html>
