            <div id="redirectUrlContainer" style="display: none">
              <div class="form-row-label">URLs</div>
              <div>
                <p
                  style="
                    color: var(--text-secondary);
                    margin-bottom: 6px;
                    font-size: 12px;
                  "
                >
                  Redirect URL:
                </p>
                <div id="redirectUrlSection" style="display: none">
                  <div class="redirect-url-box">
                    <div
                      class="redirect-url-text"
                      id="redirectUrlDisplay"
                    ></div>
                    <i class="fa-solid fa-copy" id="copyRedirectUrlIcon"></i>
                  </div>
                </div>
                <div
                  id="noEnvironmentNotice"
                  style="
                    padding: 12px;
                    background: var(--bg-surface);
                    border-radius: var(--radius-sm);
                    color: var(--text-muted);
                    font-size: 13px;
                  "
                >
                  <em
                    >Save the environment first to generate the redirect URL</em
                  >
                </div>
              </div>

              <div style="margin-top: 12px">
                <p
                  style="
                    color: var(--text-secondary);
                    margin-bottom: 6px;
                    font-size: 12px;
                  "
                >
                  Login URL:
                </p>
                <div id="loginUrlSection" style="display: none">
                  <div class="redirect-url-box">
                    <div class="redirect-url-text" id="loginUrlDisplay"></div>
                    <i class="fa-solid fa-copy" id="copyLoginUrlIcon"></i>
                  </div>
                </div>
              </div>
            </div>
          </form>
        </div>

        <div class="modal-footer">
          <button class="btn btn-ghost" id="cancelModalBtn">Cancel</button>
          <button class="btn btn-primary" id="saveEnvBtn">
            <i class="fa-solid fa-floppy-disk"></i>
            Save
          </button>
        </div>
      </div>
    </div>

    <!-- ═══════════ SCRIPTS ═══════════ -->
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <!-- DataTables -->
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <!-- Toastify -->
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <!-- NProgress -->
    <script src="https://unpkg.com/nprogress@0.2.0/nprogress.js"></script>

    <script>
      /* ── Session guard ──────────────────────────────────────── */
      const accessToken = localStorage.getItem("access_token");
      if (!accessToken) window.location.href = "/admin/login";

      /* ── Global API Response Interceptor ────────────────────── */
      const originalFetch = window.fetch;
      window.fetch = function (...args) {
        return originalFetch.apply(this, args).then((response) => {
          // Check for 401 (Unauthorized) or 403 (Forbidden)
          if (response.status === 401 || response.status === 403) {
            // Clear localStorage
            localStorage.clear();
            // Redirect to login with replace to prevent going back
            window.location.replace("/admin/login");
            // Return a rejected promise to prevent further execution
            return Promise.reject(new Error("Session expired or unauthorized"));
          }
          return response;
        });
      };

      /* helper — returns headers with Bearer token */
      function authHeaders(extra) {
        return Object.assign({ Authorization: "Bearer " + accessToken }, extra);
      }

      /* ── State ──────────────────────────────────────────────── */
      let environments = [];
      let editingId = null;
      let envDT = null;
      const wrikeRedirectUrl = "<%= wrikeRedirectUrl %>";
      const appUrl = "<%= appUrl %>";

      /* ── Toast helper ───────────────────────────────────────── */
      function toast(msg, type) {
        const palettes = {
          success: "linear-gradient(135deg, #0ecb81, #3fb950)",
          error: "linear-gradient(135deg, #f85149, #d03030)",
          info: "linear-gradient(135deg, #2f81f7, #6e40c9)",
          warning: "linear-gradient(135deg, #d29922, #e89e1d)",
        };
        Toastify({
          text: msg,
          duration: 4500,
          gravity: "top",
          position: "right",
          stopOnFocus: true,
          style: {
            background: palettes[type] || palettes.info,
            borderRadius: "8px",
            fontFamily: "'Inter', sans-serif",
            fontSize: "13.5px",
            padding: "12px 18px",
            boxShadow: "0 6px 24px rgba(0,0,0,0.4)",
            minWidth: "260px",
          },
        }).showToast();
      }

      /* ── Page map ───────────────────────────────────────────── */
      const PAGE_NAMES = {
        overview: "Overview",
        environments: "Environments",
        users: "Users",
        settings: "Settings",
      };

      /* ── Navigate ───────────────────────────────────────────── */
      function showPage(pageId) {
        $(".page").removeClass("active");
        $(`#page-${pageId}`).addClass("active");
        $(".nav-item").removeClass("active");
        $(`.nav-item[data-page="${pageId}"]`).addClass("active");

        const title = PAGE_NAMES[pageId] || pageId;
        $("#pageTitle").text(title);
        $("#breadcrumbCurrent").text(title);

        /* close mobile sidebar if open */
        $("#sidebar").removeClass("mobile-open");
      }

      /* ── Sidebar collapse ───────────────────────────────────── */
      $("#sidebarToggle").on("click", function () {
        $("#sidebar").toggleClass("collapsed");
        const collapsed = $("#sidebar").hasClass("collapsed");
        $("#toggleIcon")
          .toggleClass("fa-chevron-left", !collapsed)
          .toggleClass("fa-chevron-right", collapsed);
      });

      /* ── Mobile sidebar ─────────────────────────────────────── */
      $("#mobileSidebarBtn").on("click", function () {
        $("#sidebar").toggleClass("mobile-open");
      });

      $("#sidebar-overlay").on("click", function () {
        $("#sidebar").removeClass("mobile-open");
      });

      /* ── Nav clicks ─────────────────────────────────────────── */
      $(document).on("click", ".nav-item", function () {
        showPage($(this).data("page"));
      });

      /* ── View all link ──────────────────────────────────────── */
      $("#viewAllBtn").on("click", function () {
        showPage("environments");
      });

      /* ── Refresh ────────────────────────────────────────────── */
      $("#refreshBtn").on("click", function () {
        const $i = $(this).find("i");
        $i.addClass("fa-spin");
        loadEnvironments().finally(() =>
          setTimeout(() => $i.removeClass("fa-spin"), 600),
        );
      });

      /* ─────────────────────────────────────────────────────────
     DATA
  ───────────────────────────────────────────────────────── */
      async function loadEnvironments() {
        NProgress.start();
        try {
          const res = await fetch(`/api/v1/admin/credentials`, {
            headers: authHeaders(),
          });
          const data = await res.json();

          environments = [];
          if (data.success && Array.isArray(data.data)) {
            environments = data.data.map(function (c) {
              return {
                id: c.id,
                environment_name: c.environment_name || "",
                client_id: c.client_id || "",
                client_secret: c.client_secret || "",
                account_id: c.account_id || "",
                xpi_api_modules_datahub_id: c.xpi_api_modules_datahub_id || "",
                xpi_api_services_datahub_id:
                  c.xpi_api_services_datahub_id || "",
                xpi_entity_datahub_id: c.xpi_entity_datahub_id || "",
                xpi_field_mapping_datahub_id:
                  c.xpi_field_mapping_datahub_id || "",
                xpi_request_form_field_mapping_datahub_id:
                  c.xpi_request_form_field_mapping_datahub_id || "",
                xpi_request_form_mapping_datahub_id:
                  c.xpi_request_form_mapping_datahub_id || "",
                xpi_space_name_datahub_id: c.xpi_space_name_datahub_id || "",
                campaign_space_id: c.campaign_space_id || "",

                is_active: !!c.is_active,
                is_visible: !!c.is_visible,
                created_at: c.created_at,
                updated_at: c.updated_at,
              };
            });
          }

          renderStats();
          renderTable();
          renderRecentEnvs();
        } catch (err) {
          toast("Failed to load environments", "error");
          console.error(err);
        } finally {
          NProgress.done();
        }
      }

      /* ── Stats ──────────────────────────────────────────────── */
      function renderStats() {
        var total = environments.length;
        var active = environments.filter(function (e) {
          return e.is_active;
        }).length;
        var withCreds = environments.filter(function (e) {
          return !!e.client_id;
        }).length;

        $("#statTotal").text(total);
        $("#statActive").text(active);
        $("#statInactive").text(total - active);
        $("#statWithApi").text(withCreds);
        $("#envCount").text(total);
      }

      /* ── Date formatter for local timezone ────────────────────── */
      function formatLocalDate(dateStr) {
        if (!dateStr) return "—";
        try {
          const date = new Date(dateStr);
          return date.toLocaleString("en-US", {
            year: "numeric",
            month: "short",
            day: "numeric",
            hour: "2-digit",
            minute: "2-digit",
            second: "2-digit",
            hour12: true,
          });
        } catch (err) {
          console.log(err);
          return "--";
        }
      }

      /* ── Mask helper ────────────────────────────────────────── */
      function mask(str) {
        if (!str) return '<span class="mval">—</span>';
        var visible = escHtml(str.substring(0, Math.min(6, str.length)));
        return '<span class="mval">' + visible + "••••••</span>";
      }

      function secretMask(str) {
        return str
          ? '<span class="mval">••••••••••</span>'
          : '<span class="mval">—</span>';
      }

      /* ── XSS escape ─────────────────────────────────────────── */
      function escHtml(str) {
        return $("<div>")
          .text(str || "")
          .html();
      }

      /* ── Table ──────────────────────────────────────────────── */
      function renderTable() {
        /* Destroy existing DataTable */
        if (envDT) {
          envDT.destroy();
          envDT = null;
        }

        var $tbody = $("#envTableBody").empty();

        if (environments.length === 0) {
          $tbody.html(
            "<tr>" +
              '<td colspan="8">' +
              '<div class="empty-state">' +
              '<div class="empty-state-icon"><i class="fa-regular fa-folder-open"></i></div>' +
              "<h3>No environments found</h3>" +
              '<p>Click "Add Environment" to create the first one.</p>' +
              "</div>" +
              "</td>" +
              "</tr>",
          );
          return;
        }

        environments.forEach(function (env) {
          var badge = env.is_active
            ? '<span class="badge badge-success"><span class="dot"></span> Active</span>'
            : '<span class="badge badge-danger"><span class="dot"></span> Inactive</span>';

          var visibilityBadge = env.is_visible
            ? '<span class="badge badge-success"><span class="dot"></span> Visible</span>'
            : '<span class="badge badge-warning"><span class="dot"></span> Hidden</span>';

          $tbody.append(
            "<tr>" +
              "<td><strong>" +
              escHtml(env.environment_name) +
              "</strong></td>" +
              "<td>" +
              '<div class="action-cell">' +
              '<code style="font-size: 11px; color: var(--text-muted);">' +
              escHtml(env.id) +
              "</code>" +
              '<button class="icon-btn copy-id-btn" data-id="' +
              env.id +
              '" title="Copy ID">' +
              '<i class="fa-solid fa-copy"></i>' +
              "</button>" +
              "</div>" +
              "</td>" +
              "<td>" +
              escHtml(env.client_id) +
              "</td>" +
              "<td>" +
              formatLocalDate(env.created_at) +
              "</td>" +
              "<td>" +
              formatLocalDate(env.updated_at) +
              "</td>" +
              "<td>" +
              visibilityBadge +
              "</td>" +
              "<td>" +
              badge +
              "</td>" +
              "<td>" +
              '<div class="action-cell">' +
              '<button class="btn btn-ghost btn-sm edit-btn" data-id="' +
              env.id +
              '">' +
              '<i class="fa-solid fa-pen-to-square"></i> Edit' +
              "</button>" +
              '<button class="btn btn-danger btn-sm delete-btn" data-id="' +
              env.id +
              '" data-name="' +
              escHtml(env.environment_name) +
              '" title="Delete environment">' +
              '<i class="fa-solid fa-trash"></i> Delete' +
              "</button>" +
              "</div>" +
              "</td>" +
              "</tr>",
          );
        });

        envDT = $("#envTable").DataTable({
          pageLength: 10,
          lengthMenu: [5, 10, 25, 50],
          order: [],
          columnDefs: [
            { targets: 1, orderable: false, searchable: false },
            { targets: 7, orderable: false, searchable: false },
          ],
          language: {
            emptyTable: "No environments found",
            zeroRecords: "No matching environments",
            lengthMenu: "Show _MENU_ rows",
            search: "",
            searchPlaceholder: "Search environments…",
            info: "Showing _START_–_END_ of _TOTAL_",
            paginate: { previous: "‹", next: "›" },
          },
        });

        // Restructure DataTables wrapper to make only table scroll
        setTimeout(function () {
          var $wrapper = $("#envTable").closest(".dataTables_wrapper");
          var $table = $wrapper.find("table");
          var $filter = $wrapper.find(".dataTables_filter");
          var $length = $wrapper.find(".dataTables_length");
          var $info = $wrapper.find(".dataTables_info");
          var $paginate = $wrapper.find(".dataTables_paginate");

          // Store references and detach elements
          $table.detach();
          $filter.detach();
          $length.detach();
          $info.detach();
          $paginate.detach();

          // Create scrollable container for table
          var $scrollContainer = $(
            '<div style="overflow-x: auto; min-width: 0; flex: 1;"></div>',
          );
          $scrollContainer.append($table);

          // Create top controls section (filter and length)
          var $topControls = $(
            '<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; flex-wrap: wrap; gap: 12px;"></div>',
          );
          $topControls.append($length);
          $topControls.append($filter);

          // Create bottom controls section (info and pagination)
          var $bottomControls = $(
            '<div style="display: flex; justify-content: space-between; align-items: center; margin-top: 12px; flex-wrap: wrap; gap: 12px;"></div>',
          );
          $bottomControls.append($info);
          $bottomControls.append($paginate);

          // Empty wrapper and rebuild
          $wrapper.empty();
          $wrapper.append($topControls);
          $wrapper.append($scrollContainer);
          $wrapper.append($bottomControls);
        }, 10);
      }

      /* ── Overview recent list ───────────────────────────────── */
      function renderRecentEnvs() {
        var $body = $("#recentEnvsBody");

        if (environments.length === 0) {
          $body.html(
            '<div class="empty-state">' +
              '<div class="empty-state-icon"><i class="fa-regular fa-folder-open"></i></div>' +
              "<h3>No environments yet</h3>" +
              "<p>Add your first Wrike environment to get started.</p>" +
              "</div>",
          );
          return;
        }

        var recent = environments.slice(0, 5);
        var html =
          '<table class="dt"><thead><tr><th>Name</th><th>Env ID</th><th>Client ID</th><th>Created</th><th>Status</th><th></th></tr></thead><tbody>';

        recent.forEach(function (env) {
          console.log(env);
          var badge = env.is_active
            ? '<span class="badge badge-success"><span class="dot"></span> Active</span>'
            : '<span class="badge badge-danger"><span class="dot"></span> Inactive</span>';

          html +=
            "<tr>" +
            "<td><strong>" +
            escHtml(env.environment_name) +
            "</strong></td>" +
            "<td>" +
            '<div class="action-cell">' +
            '<code style="font-size: 11px; color: var(--text-muted);">' +
            escHtml(env.id) +
            "</code>" +
            '<button class="icon-btn copy-id-btn" data-id="' +
            env.id +
            '" title="Copy ID" style="margin-left: 4px;">' +
            '<i class="fa-solid fa-copy"></i>' +
            "</button>" +
            "</div>" +
            "</td>" +
            "<td>" +
            mask(env.client_id) +
            "</td>" +
            "<td>" +
            formatLocalDate(env?.created_at) +
            "</td>" +
            "<td>" +
            badge +
            "</td>" +
            '<td><button class="btn btn-ghost btn-sm edit-btn" data-id="' +
            env.id +
            '"><i class="fa-solid fa-pen-to-square"></i> Edit</button></td>' +
            "</tr>";
        });

        html += "</tbody></table>";
        $body.html(html);
      }

      /* ─────────────────────────────────────────────────────────
     MODAL
  ───────────────────────────────────────────────────────── */
      function openAddModal() {
        editingId = null;
        $("#modalTitle").text("Add Environment");
        $("#envForm")[0].reset();
        $("#envName").prop("disabled", false);
        $("#isVisible").prop("checked", true);
        $("#isActive").prop("checked", true);
        $("#redirectUrlContainer").hide();
        $("#envModalBackdrop").addClass("show");
        setTimeout(function () {
          $("#envName").focus();
        }, 120);
      }

      function openEditModal(id) {
        var env = environments.find(function (e) {
          return e.id === id;
        });
        if (!env) return;

        editingId = id;
        $("#modalTitle").text("Edit — " + env.environment_name);
        $("#envName").val(env.environment_name).prop("disabled", false);
        $("#clientId").val(env.client_id);
        $("#clientSecret").val(env.client_secret);
        $("#accountId").val(env.account_id);
        $("#xpiApiModulesDatahubId").val(env.xpi_api_modules_datahub_id);
        $("#xpiApiServicesDatahubId").val(env.xpi_api_services_datahub_id);
        $("#xpiEntityDatahubId").val(env.xpi_entity_datahub_id);
        $("#xpiFieldMappingDatahubId").val(env.xpi_field_mapping_datahub_id);
        $("#xpiRequestFormFieldMappingDatahubId").val(
          env.xpi_request_form_field_mapping_datahub_id,
        );
        $("#xpiRequestFormMappingDatahubId").val(
          env.xpi_request_form_mapping_datahub_id,
        );
        $("#xpiSpaceNameDatahubId").val(env.xpi_space_name_datahub_id);
        $("#campaignSpaceId").val(env.campaign_space_id);

        $("#isVisible").prop("checked", env.is_visible);
        $("#isActive").prop("checked", env.is_active);

        // Show redirect URL section for edit modal
        $("#redirectUrlContainer").show();

        // Update redirect URL display for edit modal
        if (wrikeRedirectUrl && id && appUrl) {
          // Redirect URL without environmentId
          $("#redirectUrlDisplay").text(wrikeRedirectUrl);
          $("#redirectUrlSection").show();

          // Login URL with environmentId
          const loginUrl = appUrl + "?environmentId=" + id;
          $("#loginUrlDisplay").text(loginUrl);
          $("#loginUrlSection").show();

          $("#noEnvironmentNotice").hide();
        } else {
          $("#redirectUrlSection").hide();
          $("#loginUrlSection").hide();
          $("#noEnvironmentNotice").show();
        }

        $("#envModalBackdrop").addClass("show");
        setTimeout(function () {
          $("#clientId").focus();
        }, 120);
      }

      function closeModal() {
        $("#envModalBackdrop").removeClass("show");
        editingId = null;
      }

      /* ── Redirect URL success modal ─────────────────────────── */
      function showRedirectUrlModal(redirectUrl, loginUrl) {
        $("#successRedirectUrl").text(redirectUrl);
        $("#successLoginUrl").text(loginUrl);
        $("#redirectUrlModalBackdrop").addClass("show");

        // Start countdown timer
        let countdownSeconds = 8;
        $("#countdownTimer").text(countdownSeconds);

        const countdownInterval = setInterval(function () {
          countdownSeconds--;
          $("#countdownTimer").text(countdownSeconds);

          if (countdownSeconds <= 0) {
            clearInterval(countdownInterval);
            closeRedirectUrlModal();
          }
        }, 1000);

        // Store interval ID in case we close early
        $("#redirectUrlModalBackdrop").data(
          "countdownInterval",
          countdownInterval,
        );
      }

      function closeRedirectUrlModal() {
        const interval = $("#redirectUrlModalBackdrop").data(
          "countdownInterval",
        );
        if (interval) clearInterval(interval);
        $("#redirectUrlModalBackdrop").removeClass("show");
      }

      /* ── Modal button events ────────────────────────────────── */
      $("#addEnvBtn").on("click", openAddModal);
      $("#closeModalBtn, #cancelModalBtn").on("click", closeModal);

      /* Prevent modal from closing when clicking inside the modal */
      $("#envModalBackdrop .modal").on("click", function (e) {
        e.stopPropagation();
      });

      /* Prevent modal from closing when clicking on backdrop */
      $("#envModalBackdrop").on("click", function (e) {
        e.stopPropagation();
      });

      /* ── Redirect URL modal button events ───────────────────── */
      $("#closeRedirectModalBtn, #closeRedirectModalBtnFooter").on(
        "click",
        closeRedirectUrlModal,
      );
      $("#redirectUrlModalBackdrop").on("click", function (e) {
        if (e.target === this) closeRedirectUrlModal();
      });

      /* Close on Escape */
      $(document).on("keydown", function (e) {
        if (e.key === "Escape") closeModal();
      });

      /* Edit / Delete (delegated — works for table + overview list) */
      $(document).on("click", ".edit-btn", function () {
        openEditModal($(this).data("id"));
      });

      $(document).on("click", ".delete-btn", function () {
        confirmDelete($(this).data("id"), $(this).data("name"));
      });

      /* ── Copy redirect URL (from edit modal) ──────────────────── */
      $("#copyRedirectUrlIcon").on("click", function (e) {
        e.preventDefault();
        e.stopPropagation();
        const urlText = $("#redirectUrlDisplay").text();
        if (urlText) {
          const $icon = $(this);
          const copySuccess = function () {
            // Change icon to checkmark
            $icon.removeClass("fa-copy").addClass("fa-check");
            // Revert after 1.5 seconds
            setTimeout(function () {
              $icon.removeClass("fa-check").addClass("fa-copy");
            }, 1500);
          };

          navigator.clipboard
            .writeText(urlText)
            .then(function () {
              copySuccess();
            })
            .catch(function () {
              // Fallback for older browsers
              const $temp = $("<input>");
              $("body").append($temp);
              $temp.val(urlText).select();
              document.execCommand("copy");
              $temp.remove();
              copySuccess();
            });
        }
      });

      /* ── Copy login URL (from edit modal) ────────────────────── */
      $("#copyLoginUrlIcon").on("click", function (e) {
        e.preventDefault();
        e.stopPropagation();
        const urlText = $("#loginUrlDisplay").text();
        if (urlText) {
          const $icon = $(this);
          const copySuccess = function () {
            // Change icon to checkmark
            $icon.removeClass("fa-copy").addClass("fa-check");
            // Revert after 1.5 seconds
            setTimeout(function () {
              $icon.removeClass("fa-check").addClass("fa-copy");
            }, 1500);
          };

          navigator.clipboard
            .writeText(urlText)
            .then(function () {
              copySuccess();
            })
            .catch(function () {
              // Fallback for older browsers
              const $temp = $("<input>");
              $("body").append($temp);
              $temp.val(urlText).select();
              document.execCommand("copy");
              $temp.remove();
              copySuccess();
            });
        }
      });

      /* ── Copy success URL button ───────────────────────────── */
      $("#copySuccessUrlIcon").on("click", function (e) {
        e.preventDefault();
        e.stopPropagation();
        const urlText = $("#successRedirectUrl").text();
        if (urlText) {
          const $icon = $(this);
          const copySuccess = function () {
            // Change icon to checkmark
            $icon.removeClass("fa-copy").addClass("fa-check");
            // Revert after 1.5 seconds
            setTimeout(function () {
              $icon.removeClass("fa-check").addClass("fa-copy");
            }, 1500);
          };

          navigator.clipboard
            .writeText(urlText)
            .then(function () {
              copySuccess();
            })
            .catch(function () {
              // Fallback for older browsers
              const $temp = $("<input>");
              $("body").append($temp);
              $temp.val(urlText).select();
              document.execCommand("copy");
              $temp.remove();
              copySuccess();
            });
        }
      });

      /* ── Copy success login URL button ──────────────────────── */
      $("#copySuccessLoginUrlIcon").on("click", function (e) {
        e.preventDefault();
        e.stopPropagation();
        const urlText = $("#successLoginUrl").text();
        if (urlText) {
          const $icon = $(this);
          const copySuccess = function () {
            // Change icon to checkmark
            $icon.removeClass("fa-copy").addClass("fa-check");
            // Revert after 1.5 seconds
            setTimeout(function () {
              $icon.removeClass("fa-check").addClass("fa-copy");
            }, 1500);
          };

          navigator.clipboard
            .writeText(urlText)
            .then(function () {
              copySuccess();
            })
            .catch(function () {
              // Fallback for older browsers
              const $temp = $("<input>");
              $("body").append($temp);
              $temp.val(urlText).select();
              document.execCommand("copy");
              $temp.remove();
              copySuccess();
            });
        }
      });

      /* ── Copy ID button ─────────────────────────────────────── */
      $(document).on("click", ".copy-id-btn", function (e) {
        e.preventDefault();
        e.stopPropagation();
        const $btn = $(this);
        const idValue = $btn.data("id");

        if (!idValue) return;

        navigator.clipboard
          .writeText(idValue)
          .then(function () {
            // Change icon to checkmark
            const $icon = $btn.find("i");
            $icon.removeClass("fa-copy").addClass("fa-check");
            $btn.addClass("copied");

            // Revert after 1.5 seconds
            setTimeout(function () {
              $icon.removeClass("fa-check").addClass("fa-copy");
              $btn.removeClass("copied");
            }, 1500);
          })
          .catch(function (err) {
            // Fallback for older browsers
            const $temp = $("<input>");
            $("body").append($temp);
            $temp.val(idValue).select();
            document.execCommand("copy");
            $temp.remove();

            // Change icon to checkmark
            const $icon = $btn.find("i");
            $icon.removeClass("fa-copy").addClass("fa-check");
            $btn.addClass("copied");

            // Revert after 1.5 seconds
            setTimeout(function () {
              $icon.removeClass("fa-check").addClass("fa-copy");
              $btn.removeClass("copied");
            }, 1500);
          });
      });

